{
  "apiVersion": "canvas/v1",
  "kind": "Journey",
  "metadata": {
    "name": "new-user-welcome"
  },
  "spec": {
    "trigger": {
      "type": "webhook",
      "event": "user.registered"
    },
    "nodes": [
      {
        "id": "segment",
        "type": "condition",
        "config": {
          "expression": "user.lifecycleStage == \"new\""
        }
      },
      {
        "id": "coupon",
        "type": "coupon.grant",
        "config": {
          "couponKey": "WELCOME_10"
        }
      },
      {
        "id": "message",
        "type": "message",
        "config": {
          "channel": "sms",
          "template": "welcome_coupon"
        }
      }
    ],
    "edges": [
      {
        "from": "segment",
        "to": "coupon"
      },
      {
        "from": "coupon",
        "to": "message"
      }
    ]
  }
}
