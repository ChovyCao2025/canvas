# Canvas + Feishu/Lark approval live verification environment.
# Copy this file to a local ignored path, fill values, then run:
#   scripts/verify-lark-approval-live.sh --env-file /path/to/lark-approval-live.env

# Required for all DB-backed preflight/live checks.
# export TENANT_ID=

# Canvas API endpoint.
# export API_BASE=http://localhost:8080

# Canvas JWT for the user running submit/sync/approve/reject through Canvas.
# Do not commit real tokens.
# export JWT_TOKEN=

# Canvas username represented by JWT_TOKEN.
# Required when SUBMIT_REVIEW=true; preflight checks this user has lark_open_id or lark_user_id.
# export SUBMITTER_USERNAME=alice

# Canvas id used when SUBMIT_REVIEW=true.
# Also enables DB preflight to derive project-admin approvers and check lark_open_id mappings.
# export CANVAS_ID=

# Optional comma-separated Canvas usernames that must have lark_open_id mappings before live submit.
# Use this when reviewing a fixture or when approvers are known before choosing a Canvas id.
# export EXPECTED_APPROVERS=alice,bob

# Optional direct Lark instance verification without submitting a new Canvas review.
# export LARK_INSTANCE_CODE=

# Local MySQL connection used by preflight and DB persistence checks.
# export DB_HOST=127.0.0.1
# export DB_PORT=3306
# export DB_NAME=canvas
# export DB_USER=root
# export DB_PASSWORD=

# Optional directory for non-secret verification artifacts.
# The verifier creates a timestamped subdirectory and writes responses, DB checks, and summary JSON.
# export EVIDENCE_DIR=/tmp/canvas-lark-approval-evidence

# Schema checks require lark-cli. Keep false for real readiness checks.
# export SKIP_LARK_SCHEMA=false

# Live flow toggles. Leave all false for non-destructive preflight.
# export SUBMIT_REVIEW=false
# export VERIFY_LARK_INSTANCE=false
# export SYNC_AFTER_SUBMIT=false
# export APPROVE_TASK=false
# export REJECT_TASK=false

# Optional explicit local task id for approve/reject.
# If omitted, SUBMIT_REVIEW=true can provide the first returned pending task.
# export TASK_ID=

# Approval comment sent through Canvas.
# export DECISION_COMMENT="live verification"
